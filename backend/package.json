{
  "name": "backend",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "dev": "ts-node-dev --transpile-only src/index.ts",
    "build": "tsc --noEmitOnError false",
    "fix:prisma": "chmod +x ./node_modules/.bin/prisma || true && chmod +x node_modules/.prisma/client/* || true",
    "generate": "npm run fix:prisma && npx --yes prisma generate",
    "migrate": "npm run fix:prisma && npx --yes prisma migrate deploy",
    "prestart": "npm run generate && npm run build",
    "start": "node dist/index.js",
    "postinstall": "npm run fix:prisma"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "description": "",
  "dependencies": {
    "@prisma/client": "^6.8.2",
    "@types/cors": "^2.8.18",
    "@types/express": "^5.0.1",
    "@types/jsonwebtoken": "^9.0.9",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^5.1.0",
    "groq-sdk": "^0.37.0",
    "jsonwebtoken": "^9.0.2",
    "prisma": "^6.7.0",
    "zod": "^3.24.4"
  }
}
